// Shuffle array Fisher-Yates
function shuffle(arr){
  let a=[...arr];
  for(let i=a.length-1;i>0;i--){
    const j=Math.floor(Math.random()*(i+1));
    [a[i],a[j]]=[a[j],a[i]];
  }
  return a;
}

let QST={cur:0,score:0,done:false};
let activeQS=[];     // soal yang sudah diacak
let activeOpts=[];   // pilihan yang sudah diacak per soal (simpan mapping jawaban)

function initQ(keepOrder=false){
  // Acak 10 soal dari 15 soal bank, atau pakai urutan sama
  if(keepOrder && activeQS.length>0){
    // reset state saja, soal urutan sama
  } else {
    activeQS = shuffle(QS).slice(0,10);
  }
  // Acak pilihan untuk setiap soal
  activeOpts = activeQS.map(q => {
    const indices = q.opts.map((_,i)=>i);
    const shuffledIdx = shuffle(indices);
    const newCorrect = shuffledIdx.indexOf(q.ans);
    return { shuffledIdx, newCorrect };
  });
  QST={cur:0,score:0,done:false};
  document.getElementById('qbody').style.display='block';
  document.getElementById('qresult').style.display='none';
  renderQ();
}

function renderQ(){
  const q=activeQS[QST.cur];
  const opt=activeOpts[QST.cur];
  document.getElementById('qqq').textContent=q.q;
  document.getElementById('qsub').textContent=q.sub;
  document.getElementById('qfb').className='qfb';
  document.getElementById('qnext').style.display='none';
  QST.done=false;
  // Render pilihan sesuai urutan acak
  document.getElementById('qopts').innerHTML=opt.shuffledIdx.map((origIdx,i)=>
    `<button class="qopt" onclick="ansQ(${i})">${String.fromCharCode(65+i)}. ${q.opts[origIdx]}</button>`
  ).join('');
  const pct=(QST.cur/10)*100;
  document.getElementById('qpf').style.width=pct+'%';
  document.getElementById('qsc').textContent=`Skor: ${QST.score}/${QST.cur}`;
  document.getElementById('qnum').textContent=`Soal ${QST.cur+1}/10`;
}

function ansQ(idx){
  if(QST.done)return;QST.done=true;
  const q=activeQS[QST.cur];
  const opt=activeOpts[QST.cur];
  const correctShuffled=opt.newCorrect;
  document.querySelectorAll('.qopt').forEach((b,i)=>{
    b.style.pointerEvents='none';
    if(i===correctShuffled)b.classList.add('correct');
    else if(i===idx&&idx!==correctShuffled)b.classList.add('wrong');
  });
  const fb=document.getElementById('qfb');
  if(idx===correctShuffled){QST.score++;fb.textContent='✓ Benar! '+q.exp;fb.className='qfb correct show';}
  else{fb.textContent='✗ Salah. '+q.exp;fb.className='qfb wrong show';}
  document.getElementById('qsc').textContent=`Skor: ${QST.score}/${QST.cur+1}`;
  const nxt=document.getElementById('qnext');
  nxt.style.display='block';
  nxt.textContent=QST.cur<9?'Soal Berikutnya →':'Lihat Hasil';
}

function nextQ(){
  QST.cur++;
  if(QST.cur>=10){showRes();}
  else renderQ();
}

function showRes(){
  document.getElementById('qbody').style.display='none';
  document.getElementById('qresult').style.display='block';
  document.getElementById('qpf').style.width='100%';
  const pct=Math.round(QST.score/10*100);
