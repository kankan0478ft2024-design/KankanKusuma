<script>
// ==============================
// GLOBALS
// ==============================
let bits=[], active=new Set(['nrz-l','nrz-i','ami','manchester']);
const BW=58, CH=70;
const COL={'nrz-l':'#4f6fff','nrz-i':'#00c9a7','ami':'#ff6b6b','manchester':'#ffd166','diff-man':'#c77dff','rz':'#ff9f1c','b8zs':'#e76f51'};
const LAB={'nrz-l':'NRZ-L','nrz-i':'NRZ-I','ami':'AMI','manchester':'Manchester','diff-man':'Diff. Manchester','rz':'RZ','b8zs':'B8ZS'};
const ORDER=['nrz-l','nrz-i','ami','manchester','diff-man','rz','b8zs'];

// ==============================
// TABS
// ==============================
function sw(id,el){
  document.querySelectorAll('.sec').forEach(s=>s.classList.remove('on'));
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('on'));
  document.getElementById('sec-'+id).classList.add('on');
  el.classList.add('on');
  if(id==='quiz') initQ();
}

// ==============================
// BIT INPUT
// ==============================
function onBit(){
  let v=document.getElementById('bitIn').value.replace(/[^01]/g,'');
  document.getElementById('bitIn').value=v;
  bits=v.split('').map(Number);
  renderBits(); renderAll();
  document.getElementById('bhint').textContent=bits.length?`${bits.length} bit · ${bits.filter(b=>b).length} satu · ${bits.filter(b=>!b).length} nol`:'Ketik kombinasi 0 dan 1';
}
function loadPre(v){if(!v)return;document.getElementById('bitIn').value=v;onBit();}
function renderBits(){
  const el=document.getElementById('bdis');
  el.innerHTML=bits.map(b=>`<div class="bc b${b}">${b}</div>`).join('');
}

// ==============================
// METHOD TOGGLE
// ==============================
function tog(m,btn){
  if(active.has(m)){if(active.size===1)return;active.delete(m);btn.classList.remove('on');}
  else{active.add(m);btn.classList.add('on');}
  renderAll();
}

// ==============================
// ENCODERS
// ==============================
function encNRZL(b){
  let p=[];b.forEach((x,i)=>{let v=x?1:-1;p.push({x:i*BW,y:v},{x:(i+1)*BW,y:v});});return p;
}
function encNRZI(b){
  let p=[],lv=-1;
  b.forEach((x,i)=>{if(x)lv=-lv;p.push({x:i*BW,y:lv},{x:(i+1)*BW,y:lv});});return p;
}
function encAMI(b){
  let p=[],last=1;
  b.forEach((x,i)=>{let v=x?(last=-last,last):0;p.push({x:i*BW,y:v},{x:(i+1)*BW,y:v});});return p;
}
function encRZ(b){
  let p=[];
  b.forEach((x,i)=>{
    let x0=i*BW,xm=x0+BW/2,x1=(i+1)*BW;
    if(x){p.push({x:x0,y:1},{x:xm,y:1},{x:xm,y:0},{x:x1,y:0});}
    else{p.push({x:x0,y:0},{x:x1,y:0});}
  });return p;
}
function encManchester(b){
  let p=[];
  b.forEach((x,i)=>{
    let x0=i*BW,xm=x0+BW/2,x1=(i+1)*BW;
    if(x){p.push({x:x0,y:1},{x:xm,y:1},{x:xm,y:-1},{x:x1,y:-1});}
    else{p.push({x:x0,y:-1},{x:xm,y:-1},{x:xm,y:1},{x:x1,y:1});}
  });return p;
}
function encDiffMan(b){
  let p=[],lv=-1;
  b.forEach((x,i)=>{
    let x0=i*BW,xm=x0+BW/2,x1=(i+1)*BW;
    if(!x)lv=-lv;
    p.push({x:x0,y:lv},{x:xm,y:lv},{x:xm,y:-lv},{x:x1,y:-lv});
    lv=-lv;
  });return p;
}
function encB8ZS(b){
  // AMI-based with 8-zero substitution
  let sig=[],last=1;
  let i=0;
  while(i<b.length){
    if(b[i]===0){
      // check for 8 consecutive zeros
      let zeros=0;
      for(let j=i;j<b.length&&b[j]===0;j++)zeros++;
      if(zeros>=8){
        // substitute: 000VB0VB
        // V=violation (same as last), B=balancing (opposite of last)
        let seq=[0,0,0,last,-last,0,-last,last];
        last=last; // after B8ZS last non-zero is the B pulse
        for(let k=0;k<8;k++)sig.push(seq[k]);
        last=seq[7]; // update last to the last non-zero
        i+=8;
      } else {
        sig.push(0); i++;
      }
    } else {
      last=-last; sig.push(last); i++;
    }
  }
  let p=[];
  sig.forEach((v,i)=>{p.push({x:i*BW,y:v},{x:(i+1)*BW,y:v});});
  return p;
}

function getEnc(m,b){
  switch(m){
    case'nrz-l':return encNRZL(b);
    case'nrz-i':return encNRZI(b);
    case'ami':return encAMI(b);
    case'manchester':return encManchester(b);
    case'diff-man':return encDiffMan(b);
    case'rz':return encRZ(b);
    case'b8zs':return encB8ZS(b);
  }
  return [];
}

// ==============================
// DRAW
// ==============================
function draw(canvas,pts,col){
  const ctx=canvas.getContext('2d'),W=canvas.width,H=canvas.height,mid=H/2,amp=mid-14;
  ctx.clearRect(0,0,W,H);
  // zero line
  ctx.strokeStyle='rgba(90,110,200,.1)';ctx.lineWidth=.5;
  ctx.beginPath();ctx.moveTo(40,mid);ctx.lineTo(W,mid);ctx.stroke();
  // level lines
  ctx.strokeStyle='rgba(90,110,200,.06)';
  ctx.beginPath();ctx.moveTo(40,mid-amp);ctx.lineTo(W,mid-amp);ctx.moveTo(40,mid+amp);ctx.lineTo(W,mid+amp);ctx.stroke();
  // labels
  ctx.fillStyle='rgba(139,149,176,.5)';ctx.font='8px Space Mono,monospace';ctx.textAlign='right';
  ctx.fillText('+V',37,mid-amp+3);ctx.fillText('0V',37,mid+3);ctx.fillText('-V',37,mid+amp+3);
  if(!pts||!pts.length)return;
  const ty=v=>mid-v*amp, tx=x=>x+40;
  // period dividers
  ctx.strokeStyle='rgba(90,110,200,.12)';ctx.lineWidth=.5;ctx.setLineDash([2,3]);
  for(let i=0;i<=bits.length;i++){let x=tx(i*BW);ctx.beginPath();ctx.moveTo(x,5);ctx.lineTo(x,H-5);ctx.stroke();}
  ctx.setLineDash([]);
  // waveform
  ctx.strokeStyle=col;ctx.lineWidth=2;ctx.shadowColor=col;ctx.shadowBlur=5;ctx.lineJoin='miter';
  ctx.beginPath();
  pts.forEach((pt,i)=>{
    let x=tx(pt.x),y=ty(pt.y);
    if(i===0)ctx.moveTo(x,y);else ctx.lineTo(x,y);
  });
  ctx.stroke();ctx.shadowBlur=0;
  // bit labels
  ctx.fillStyle='rgba(139,149,176,.55)';ctx.font='8px Space Mono,monospace';ctx.textAlign='center';
  bits.forEach((b,i)=>ctx.fillText(b,tx(i*BW+BW/2),H-2));
}

// ==============================
// RENDER ALL
// ==============================
function renderAll(){
  const wa=document.getElementById('warea'),sa=document.getElementById('sarea'),tc=document.getElementById('traceCard');
  if(!bits.length){
    wa.innerHTML='<div class="empty">↑ Masukkan bit stream untuk melihat gelombang</div>';
    sa.style.display='none';tc.style.display='none';return;
  }
  const methods=ORDER.filter(m=>active.has(m));
  const cW=bits.length*BW+42;
  let html='<div class="wbox">';
  methods.forEach(m=>{
    html+=`<div class="wrow" style="margin-bottom:14px"><div class="wlabel" style="color:${COL[m]}">${LAB[m]}</div><canvas class="wc" id="cv-${m}" width="${cW}" height="${CH}"></canvas></div>`;
  });
  html+='</div>';
  wa.innerHTML=html;
  methods.forEach(m=>{
    const c=document.getElementById('cv-'+m);
    if(c)draw(c,getEnc(m,bits),COL[m]);
  });
  // stats
  sa.style.display='block';
  const ones=bits.filter(b=>b).length,zeros=bits.length-ones;
  document.getElementById('srow').innerHTML=`
    <div class="sc">Panjang: <b>${bits.length}</b></div>
    <div class="sc">Bit 1: <b>${ones}</b></div>
    <div class="sc">Bit 0: <b>${zeros}</b></div>
    <div class="sc">Metode aktif: <b>${methods.length}</b></div>
    <div class="sc">Est. Bandwidth (NRZ): <b>${bits.length} bps = ${bits.length} baud</b></div>
  `;
  // trace
  tc.style.display='block';
  let lvls={};
  methods.forEach(m=>lvls[m]=getLevels(m,bits));
  let th='<div class="trace-wrap"><table class="tr"><thead><tr><th>#</th><th>Bit</th>';
  methods.forEach(m=>`${th+=`<th style="color:${COL[m]}">${LAB[m]}</th>`}`);
  th+='</tr></thead><tbody>';
  bits.forEach((b,i)=>{
    let bcolor=b?'var(--accent2)':'var(--text3)';
    th+=`<tr><td style="color:var(--text3)">${i+1}</td><td style="color:${bcolor}">${b}</td>`;
    methods.forEach(m=>{
      let v=lvls[m][i],s=v===1?'+V':v===-1?'-V':'0V',col=v===1?'var(--accent2)':v===-1?'var(--c3)':'var(--text3)';
      if(typeof v==='string'){s=v;col='var(--text2)';}
      th+=`<td style="color:${col}">${s}</td>`;
    });
    th+='</tr>';
  });
  th+='</tbody></table></div>';
  document.getElementById('traceBody').innerHTML=th;
}

function getLevels(m,b){
  if(m==='nrz-l')return b.map(x=>x?1:-1);
  if(m==='nrz-i'){let lv=-1;return b.map(x=>{if(x)lv=-lv;return lv;});}
  if(m==='ami'){let l=1;return b.map(x=>x?(l=-l,l):0);}
  if(m==='rz')return b.map(x=>x?'H→0':'0');
  if(m==='manchester')return b.map(x=>x?'H→L':'L→H');
  if(m==='diff-man')return b.map(x=>x?'Tetap':'Trans');
  if(m==='b8zs')return b.map((_,i)=>'see wave');
  return b.map(()=>'—');
}


